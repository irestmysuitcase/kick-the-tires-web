---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kick the Tires — Erkenne sofort, ob ein Auto sein Geld wert ist">

  <!-- Nav -->
  <nav class="max-w-6xl mx-auto px-6 py-6 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <span class="text-xl">🛞</span>
      <span class="text-lg font-bold text-slate-900 tracking-tight">Kick the Tires</span>
    </div>
    <a href="/privacy" class="text-sm text-slate-500 hover:text-slate-800 transition-colors">
      Datenschutzerklärung
    </a>
  </nav>

  <!-- Hero -->
  <section class="py-24 md:py-32 px-6 text-center">
    <div class="max-w-4xl mx-auto">
      <p class="text-[#FBBC04] font-semibold text-sm tracking-widest uppercase mb-6">Kostenlose Chrome Extension</p>
      <h1 class="text-5xl md:text-7xl font-bold text-slate-900 leading-tight mb-8 tracking-tight">
        Finde in Sekunden heraus, <span class="text-[#FBBC04]">ob ein Auto sein Geld wert ist</span>
      </h1>
      <p class="text-xl text-slate-600 leading-relaxed mb-10 max-w-2xl mx-auto">
        Online-Marktplätze sind für Händler gemacht. <br>Kick the Tires für dich.
      </p>
      <p class="text-lg text-slate-600 leading-relaxed mb-10 max-w-3xl mx-auto">
        Erhalte für jedes Inserat auf AutoScout24 ein klares Urteil: <span class="text-emerald-600">Empfehlenswert</span>, <span class="text-amber-500">Vorsicht</span> oder <span class="text-red-500">Vermeiden</span>.
        Erkenne versteckte Probleme, typische Reparaturkosten und worauf dich Verkäufer nicht hinweisen — noch bevor du den Verkäufer kontaktierst.
      </p>
      <a
        id="hero-cta"
        href="#"
        class="inline-flex items-center bg-slate-200 text-slate-500 font-semibold px-8 py-4 rounded-full text-base cursor-not-allowed"
      >
        Coming Soon to Chrome Web Store
      </a>
      <p class="text-sm text-slate-500 mt-4 font-medium">Zahle keinen Franken zu viel für dein nächstes Auto</p>
      <p class="text-sm text-slate-400 mt-2">Funktioniert auf AutoScout24.ch · Weitere Online-Marktplätze folgen</p>
    </div>
  </section>

  <!-- How it works -->
  <section class="bg-slate-100">
    <div class="max-w-6xl mx-auto px-6 py-20 md:py-24">
      <p class="text-[#FBBC04] font-semibold text-sm tracking-widest uppercase mb-4">So funktioniert’s</p>
      <h2 class="text-4xl font-bold text-slate-900 mb-20">Erkenne, was das Inserat nicht verrät</h2>

      <div class="grid md:grid-cols-2 gap-12 md:gap-16">
        <!-- Feature 1 -->
        <div>
          <div class="h-80 overflow-hidden rounded-xl shadow-lg border border-slate-200 mb-8">
            <img
              src="/search-results.png"
              alt="AutoScout24 search results with Kick the Tires verdict badges showing Recommended, Caution, and Avoid labels on each listing"
              class="w-full h-full object-cover object-top"
            />
          </div>
          <h3 class="text-xl font-semibold text-slate-900 mb-3">Riskante Angebote sofort erkennen</h3>
          <p class="text-slate-600 leading-relaxed">
            Jedes Inserat erhält ein klares Urteil — <span class="text-emerald-600 font-medium">Empfehlenswert</span>, <span class="text-amber-500 font-medium">Vorsicht</span> oder <span class="text-red-500 font-medium">Vermeiden</span> — damit du riskante Autos auf einen Blick ausschliessen kannst.
          </p>
        </div>

        <!-- Feature 2 -->
        <div>
          <div class="h-80 overflow-hidden rounded-xl shadow-lg border border-slate-200 mb-8">
            <img
              src="/detail-page.png"
              alt="AutoScout24 car detail page showing the Kick the Tires panel with reliability ratings, known issues, repair costs, and questions to ask the seller"
              class="w-full h-full object-cover object-top"
            />
          </div>
          <h3 class="text-xl font-semibold text-slate-900 mb-3">Die echten Kosten verstehen</h3>
          <p class="text-slate-600 leading-relaxed">
            Öffne das Kick the Tires Panel und sieh bekannte Probleme für den jeweiligen Motor, typische Reparaturkosten und gezielte Fragen, die du dem Verkäufer stellen solltest.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why it matters -->
  <section class="bg-white">
    <div class="max-w-6xl mx-auto px-6 py-20 md:py-24">
      <p class="text-[#FBBC04] font-semibold text-sm tracking-widest uppercase mb-4">Warum das wichtig ist</p>
      <h2 class="text-4xl font-bold text-slate-900 mb-6">Das Risiko steckt oft im Detail</h2>
      <p class="text-slate-600 text-lg max-w-3xl mb-12">
        Inserate zeigen nur, was Verkäufer zeigen wollen. Kick the Tires hilft dir zu erkennen, was fehlt.
      </p>

      <div class="grid md:grid-cols-2 gap-6 md:gap-8">
        <div class="rounded-2xl border border-slate-200 p-6 md:p-8 bg-slate-50">
          <h3 class="text-xl font-semibold text-slate-900 mb-4">Ohne Kick the Tires</h3>
          <ul class="space-y-3 text-slate-600">
            <li>Du schätzt, ob der Preis fair ist</li>
            <li>Versteckte Zuverlässigkeitsprobleme bleiben unentdeckt</li>
            <li>Risiko von teuren Überraschungen</li>
          </ul>
        </div>

        <div class="rounded-2xl border border-[#FBBC04]/60 p-6 md:p-8 bg-amber-50/60 shadow-md">
          <h3 class="text-xl font-semibold text-slate-900 mb-4">Mit Kick the Tires</h3>
          <ul class="space-y-3 text-slate-700">
            <li>Du erhältst sofort ein klares Urteil</li>
            <li>Du erkennst bekannte Probleme und typische Reparaturkosten</li>
            <li>Du kontaktierst Verkäufer besser vorbereitet</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust -->
  <section class="bg-slate-100 border-y border-slate-200/70">
    <div class="max-w-6xl mx-auto px-6 py-12">
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-white border border-slate-200 rounded-lg px-4 py-3 text-sm text-slate-700 font-medium">Entwickelt für den Schweizer Occasionsmarkt</div>
        <div class="bg-white border border-slate-200 rounded-lg px-4 py-3 text-sm text-slate-700 font-medium">Funktioniert direkt auf AutoScout24.ch</div>
        <div class="bg-white border border-slate-200 rounded-lg px-4 py-3 text-sm text-slate-700 font-medium">Chrome Extension – einfach installiert, direkt nutzbar</div>
        <div class="bg-white border border-slate-200 rounded-lg px-4 py-3 text-sm text-slate-700 font-medium">Fokus auf Käufer statt Verkäufer</div>
      </div>
    </div>
  </section>

  <!-- Supported models -->
  <section class="bg-white">
    <div class="max-w-6xl mx-auto px-6 py-20 md:py-24">
      <p class="text-[#FBBC04] font-semibold text-sm tracking-widest uppercase mb-4">Unterstützte Modelle</p>
      <h2 class="text-4xl font-bold text-slate-900 mb-6">Start mit den beliebtesten Modellen — laufend erweitert</h2>
      <p class="text-slate-600 mb-12 text-lg">Kick the Tires unterstützt aktuell die meist beliebte Modelle auf AutoScout24.ch. Weitere kommen regelmässig dazu.</p>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          'BMW 3er',
          'BMW 5er',
          'BMW 7er',
          'Mercedes C-Klasse',
          'Mercedes CLA',
          'Mercedes CLS',
          'Mercedes E-Klasse',
        ].map((model) => (
          <div class="bg-white border border-slate-200 border-l-4 border-l-[#FBBC04] rounded-lg px-4 py-3 text-sm text-slate-700 font-medium shadow-sm">
            {model}
          </div>
        ))}
        <div class="bg-white border border-dashed border-slate-300 rounded-lg px-4 py-3 text-sm text-slate-500 italic">
          Weitere folgen.
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-slate-100 border-t border-slate-200">
    <div class="max-w-4xl mx-auto px-6 py-16 md:py-20 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4"><span class="text-[#FBBC04]">Zahle keinen Franken zu viel</span><br> für dein nächstes Auto</h2>
      <p class="text-lg text-slate-600 mb-8">Kick the Tires hilft dir, riskante Angebote zu erkennen — noch bevor du den Verkäufer kontaktierst.</p>
      <a
        href="#hero-cta"
        class="inline-flex items-center bg-slate-200 text-slate-500 font-semibold px-8 py-4 rounded-full text-base cursor-not-allowed"
      >
        Coming Soon to Chrome Web Store
      </a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-slate-200">
    <div class="max-w-6xl mx-auto px-6 py-10 flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-slate-400">
      <p>© 2026 Kick the Tires · Entwickelt in der Schweiz</p>
      <div class="flex items-center gap-6">
        <a href="/privacy" class="hover:text-slate-700 transition-colors">Datenschutzerklärung</a>
        <a href="mailto:hello@kickthetires.ch" class="hover:text-slate-700 transition-colors">hello@kickthetires.ch</a>
        <span>Coming Soon to Chrome Web Store</span>
      </div>
    </div>
  </footer>

  <!-- Sticky CTA bar -->
  <div
    id="sticky-cta"
    class="fixed bottom-0 left-0 right-0 z-50 bg-white/95 backdrop-blur border-t border-slate-200 shadow-lg py-2.5 translate-y-full transition-transform duration-300"
  >
    <div class="flex justify-center px-4">
      <a
        href="#"
        class="inline-flex items-center bg-slate-200 text-slate-500 font-semibold px-8 py-4 rounded-full text-base cursor-not-allowed w-full max-w-sm justify-center md:w-auto"
      >
        Coming Soon to Chrome Web Store
      </a>
    </div>
  </div>

  <script>
    const heroCta = document.getElementById('hero-cta');
    const stickyCta = document.getElementById('sticky-cta');

    const observer = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting) {
        stickyCta.classList.add('translate-y-full');
      } else {
        stickyCta.classList.remove('translate-y-full');
      }
    });

    observer.observe(heroCta);
  </script>

</Layout>
