---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kick the Tires — Car Reliability Intelligence for AutoScout24">

  <!-- Nav -->
  <nav class="max-w-6xl mx-auto px-6 py-6 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <span class="text-xl">🛞</span>
      <span class="text-lg font-bold text-slate-900 tracking-tight">Kick the Tires</span>
    </div>
    <a href="/privacy" class="text-sm text-slate-500 hover:text-slate-800 transition-colors">
      Privacy Policy
    </a>
  </nav>

  <!-- Hero -->
  <section class="py-32 md:py-40 px-6 text-center">
    <div class="max-w-4xl mx-auto">
      <p class="text-[#FBBC04] font-semibold text-sm tracking-widest uppercase mb-6">Free Chrome Extension</p>
      <h1 class="text-5xl md:text-7xl font-bold text-slate-900 leading-tight mb-8 tracking-tight">
        The marketplace works for dealers.<br />
        <span class="text-[#FBBC04]">Kick the Tires works for you.</span>
      </h1>
      <p class="text-xl text-slate-600 leading-relaxed mb-10 max-w-2xl mx-auto">
        Know what you're really buying before you contact the seller. Kick the Tires adds reliability intelligence directly to AutoScout24 listings — known issues, repair costs, and honest verdicts.
      </p>
      <a
        href="#"
        class="inline-flex items-center gap-2 bg-[#FBBC04] text-slate-900 font-semibold px-8 py-4 rounded-full shadow-md hover:bg-[#f5b400] transition-colors text-base"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
        </svg>
        Add to Chrome — It's Free
      </a>
      <p class="text-sm text-slate-400 mt-4">Works on AutoScout24.ch · More Marketplaces Coming Soon</p>
    </div>
  </section>

  <!-- How it works -->
  <section class="bg-slate-100">
    <div class="max-w-6xl mx-auto px-6 py-24 md:py-32">
      <p class="text-[#FBBC04] font-semibold text-sm tracking-widest uppercase mb-4">How it works</p>
      <h2 class="text-4xl font-bold text-slate-900 mb-20">Reliability intel, right where you need it.</h2>

      <div class="grid md:grid-cols-2 gap-12 md:gap-16">
        <!-- Feature 1 -->
        <div>
          <div class="bg-slate-200 rounded-xl shadow-sm aspect-video flex items-center justify-center mb-8">
            <span class="text-slate-400 text-sm">Screenshot: search results with verdict badges</span>
          </div>
          <h3 class="text-xl font-semibold text-slate-900 mb-3">Instant verdicts on search results</h3>
          <p class="text-slate-600 leading-relaxed">
            Every listing gets a verdict badge — <span class="text-emerald-600 font-medium">Recommended</span>, <span class="text-amber-500 font-medium">Caution</span>, or <span class="text-red-500 font-medium">Avoid</span> — so you can spot problem cars at a glance.
          </p>
        </div>

        <!-- Feature 2 -->
        <div>
          <div class="bg-slate-200 rounded-xl shadow-sm aspect-video flex items-center justify-center mb-8">
            <span class="text-slate-400 text-sm">Screenshot: detail page HUD</span>
          </div>
          <h3 class="text-xl font-semibold text-slate-900 mb-3">The full picture on every car</h3>
          <p class="text-slate-600 leading-relaxed">
            Open the Kick the Tires panel on any detail page to see reliability and running cost ratings, known issues for that specific engine, typical repair costs in CHF, and questions to ask the seller.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Supported models -->
  <section class="bg-white">
    <div class="max-w-6xl mx-auto px-6 py-24 md:py-32">
      <p class="text-[#FBBC04] font-semibold text-sm tracking-widest uppercase mb-4">Supported models</p>
      <h2 class="text-4xl font-bold text-slate-900 mb-6">Growing coverage, starting with the most popular.</h2>
      <p class="text-slate-600 mb-12 text-lg">Currently covering 7 popular models on AutoScout24.ch, with more added regularly.</p>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          'BMW 3 Series',
          'BMW 5 Series',
          'BMW 7 Series',
          'Mercedes C-Class',
          'Mercedes CLA',
          'Mercedes CLS',
          'Mercedes E-Class',
        ].map((model) => (
          <div class="bg-white border border-slate-200 border-l-4 border-l-[#FBBC04] rounded-lg px-4 py-3 text-sm text-slate-700 font-medium shadow-sm">
            {model}
          </div>
        ))}
        <div class="bg-white border border-dashed border-slate-300 rounded-lg px-4 py-3 text-sm text-slate-400 italic">
          More coming soon…
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-slate-200">
    <div class="max-w-6xl mx-auto px-6 py-10 flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-slate-400">
      <p>© {new Date().getFullYear()} Kick the Tires · Built in Switzerland</p>
      <div class="flex items-center gap-6">
        <a href="/privacy" class="hover:text-slate-700 transition-colors">Privacy Policy</a>
        <a href="mailto:info@kickthetires.ch" class="hover:text-slate-700 transition-colors">info@kickthetires.ch</a>
      </div>
    </div>
  </footer>

</Layout>
